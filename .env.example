# Nebius API key — load from 1Password:
#   op read "op://Clawdbot/Nebius Token Factory - Datahub Hackathon/notesPlain"
NEBIUS_API_KEY=

# DataHub Core on Studio A via Tailscale
DATAHUB_GMS_URL=http://100.114.31.63:8080
DATAHUB_UI_URL=http://100.114.31.63:9002

# DataHub Personal Access Token
# Generate at: http://100.114.31.63:9002/settings/tokens
DATAHUB_GMS_TOKEN=

# Slack webhook (optional — Fixer falls back to terminal print if unset)
SLACK_WEBHOOK_URL=

# ───── Model lineup (Nebius slugs, locked) ─────
COORDINATOR_MODEL=moonshotai/Kimi-K2-Thinking
DETECTIVE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
REALITY_CHECKER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
FIXER_MODEL=MiniMaxAI/MiniMax-M2.5

# NL→GraphQL translator — swap to fine-tuned LoRA endpoint when right terminal delivers
# Mode "plan_b" loads in-context seed examples as the system prompt
NL_TO_GRAPHQL_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
NL_TO_GRAPHQL_MODE=plan_b

# Dashboard
DASHBOARD_PORT=8001
DASHBOARD_HOST=127.0.0.1
